{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["bookstore"],
  "properties": {
    "bookstore": {
      "type": "object",
      "required": ["books"],
      "properties": {
        "books": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "title", "author", "price", "category", "available"],
            "properties": {
              "id": { "type": "integer" },
              "title": { "type": "string" },
              "author": { "type": "string" },
              "price": { "type": "number", "minimum": 0 },
              "category": { "type": "string" },
              "available": { "type": "boolean" }
            }
          }
        }
      }
    }
  }
}